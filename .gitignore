# Generated code and benchmark artifacts. Everything here is reproducible by
# running `bench/run_bench.sh` (which also runs the `go run .` generator), so it
# is kept out of version control. The hand-written sources -- bench/*/data.go,
# the small bench/*/input.json (cases without an input.url), the scripts, main.go
# and pkg/support -- remain tracked.

# Lightning-generated unmarshalers (`// Code generated by the lightning generator ... DO NOT EDIT`).
# Covers the bench decoders (reproduced by bench/run_bench.sh) and
# conformance/data_unmarshal.go (reproduced by `make check`, via its Makefile rule).
*_unmarshal.go

# Benchmark harness written by bench/run_bench.sh (`// Code generated ... DO NOT EDIT`)
bench/*/bench_test.go

# easyjson sub-packages: the copied struct and the easyjson output are both generated
bench/*/ej/

# Benchmark output (machine-specific timings; regenerated each run)
bench/results.txt

# Inputs fetched on demand: each case below ships a committed input.url that
# run_bench.sh downloads (and gunzips) into input.json when absent -- the ~8 MB
# SF citylots GeoJSON and the go-json-experiment/jsonbench corpus. Too large
# and/or freely reproducible to commit; the small hand-written inputs stay tracked.
bench/large-json/input.json
bench/canada_geometry/input.json
bench/citm_catalog/input.json
bench/golang_source/input.json
bench/string_unicode/input.json
bench/synthea_fhir/input.json
bench/twitter_status/input.json

# Compiled generator binary, if `go build .` is ever run without -o /dev/null
/lightning

# Compiled Go test binaries (`go test -c`), e.g. the ones the A/B bench harness
# builds into bench/ — never artifacts to commit.
*.test

# Simdjson-go testdata bench inputs (downloaded from input.url by run_bench.sh)
bench/apache_builds/input.json
bench/canada/input.json
bench/github_events/input.json
bench/gsoc_2018/input.json
bench/instruments/input.json
bench/marine_ik/input.json
bench/mesh/input.json
bench/mesh_pretty/input.json
bench/numbers/input.json
bench/payload_large/input.json
bench/payload_medium/input.json
bench/payload_small/input.json
bench/random/input.json
bench/twitterescaped/input.json
bench/update_center/input.json
